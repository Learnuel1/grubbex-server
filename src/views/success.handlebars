<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payment Successful - Grubbex</title>
  <style>
    /* ---------- reset and base ---------- */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: #f4f6f9;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      margin: 0;
      padding: 20px;
    }

    .card {
      background: #ffffff;
      padding: 40px 35px;
      border-radius: 16px;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
      text-align: center;
      max-width: 480px;
      width: 100%;
      transition: all 0.2s ease;
    }

    .card:hover {
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    }

    .icon-wrapper {
      background: #e6f7e6;
      width: 80px;
      height: 80px;
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      margin: 0 auto 20px;
    }

    .checkmark {
      font-size: 44px;
      color: #2e7d32;
      line-height: 1;
    }

    h1 {
      color: #1e293b;
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .subtitle {
      color: #475569;
      font-size: 16px;
      margin-bottom: 20px;
    }

    .details {
      background: #f8fafc;
      border-radius: 10px;
      padding: 16px 20px;
      text-align: left;
      margin: 20px 0 28px;
      font-size: 14px;
    }

    .details-row {
      display: flex;
      justify-content: space-between;
      padding: 6px 0;
      border-bottom: 1px solid #e9edf2;
    }

    .details-row:last-child {
      border-bottom: none;
    }

    .details-label {
      color: #64748b;
      font-weight: 500;
    }

    .details-value {
      color: #0f172a;
      font-weight: 600;
      word-break: break-all;
    }

    .btn {
      display: inline-block;
      background: #0f172a;
      color: white;
      padding: 12px 28px;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 600;
      font-size: 16px;
      transition: background 0.2s ease;
      border: none;
      cursor: pointer;
    }

    .btn:hover {
      background: #1e293b;
    }

    .btn-outline {
      background: transparent;
      color: #0f172a;
      border: 2px solid #e2e8f0;
      margin-left: 10px;
    }

    .btn-outline:hover {
      background: #f1f5f9;
      border-color: #cbd5e1;
    }

    .footer-text {
      margin-top: 25px;
      font-size: 13px;
      color: #94a3b8;
    }

    .footer-text a {
      color: #0f172a;
      text-decoration: none;
      font-weight: 600;
    }

    .footer-text a:hover {
      text-decoration: underline;
    }

    @media (max-width: 480px) {
      .card {
        padding: 30px 20px;
      }
      h1 {
        font-size: 24px;
      }
      .details {
        font-size: 13px;
        padding: 12px 16px;
      }
      .btn {
        display: block;
        width: 100%;
        margin: 8px 0;
      }
      .btn-outline {
        margin-left: 0;
      }
    }
  </style>
</head>
<body>

  <div class="card">
    <div class="icon-wrapper">
      <span class="checkmark">✓</span>
    </div>

    <h1>Payment Successful!</h1>
    <p class="subtitle">Your transaction has been completed.</p>

    <div class="details">
      <div class="details-row">
        <span class="details-label">Reference</span>
        <span class="details-value">{{ reference }}</span>
      </div>
      {{#if orderId}}
      <div class="details-row">
        <span class="details-label">Order ID</span>
        <span class="details-value">{{ orderId }}</span>
      </div>
      {{/if}}
      {{#if amount}}
      <div class="details-row">
        <span class="details-label">Amount</span>
        <span class="details-value">₦{{ amount }}</span>
      </div>
      {{/if}}
      {{#if email}}
      <div class="details-row">
        <span class="details-label">Customer</span>
        <span class="details-value">{{ email }}</span>
      </div>
      {{/if}}
    </div>
 

    <div class="footer-text">
      Need help? <a href="{{contact}}">Contact support</a>
    </div>
  </div>

</body>
</html>