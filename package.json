{
  "name": "grubber-ex-backend",
  "version": "1.0.0",
  "description": "This is the backend API Server for the GrubberEx User, driver, business and Admin dashboards.",
  "main": "server.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "rimraf ",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start-prod": "node ./prod_build/main.js",
    "build:prod": "webpack --config ./webpack.prod.js --mode production",
    "pm2": "pm2 start ../ecosystem.config.js --name grubbex-backend && pm2 reload grubbex-backend && pm2 logs grubbex-backend",
    "pm2-stop": "pm2 stop grubbex-backend && pm2 delete all"
  },
